{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Run Both",
      "configurations": ["API", "Blazor"]
    }
  ],
  "configurations": [
    {
      "name": "API",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/API/bin/Debug/net8.0/API.dll",
      "cwd": "${workspaceFolder}/API",
      "env": {
        "ASPNETCORE_URLS": "http://localhost:5240"
      }
    },
    {
      "name": "Blazor",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/BlazorApp/bin/Debug/net8.0/BlazorApp.dll",
      "cwd": "${workspaceFolder}/BlazorApp",
      "env": {
        "ASPNETCORE_URLS": "http://localhost:5068"
      }
    }
  ]
}